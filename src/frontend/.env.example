# .env.example — Template for required environment variables.
# Copy this file to .env and fill in the values.

# URL of the ASP.NET backend API (no trailing slash).
VITE_API_BASE_URL=http://localhost:5000

# ── Mattermost chat integration (optional) ────────────────────────────
# Set these to enable the embedded chat panel.
VITE_MATTERMOST_URL=
VITE_MATTERMOST_WS_URL=
VITE_MATTERMOST_TOKEN=
VITE_MATTERMOST_TEAM_ID=
