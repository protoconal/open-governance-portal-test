# ─── Directus Configuration ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# See https://docs.directus.io/self-hosted/config-options.html

# ─── General ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8055
PUBLIC_URL=http://localhost:8055
LOG_LEVEL=info

# ─── Secrets ─────────────────────────────────────────────────────────────
# Generate unique values for production.
# You can use: npx directus generate-secret
KEY=replace-with-a-random-uuid
SECRET=replace-with-a-random-secret

# ─── Database ────────────────────────────────────────────────────────────
# SQLite (default — good for development)
DB_CLIENT=sqlite3
DB_FILENAME=./data/database.sqlite

# PostgreSQL (recommended for production):
# DB_CLIENT=pg
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=governance_portal
# DB_USER=directus
# DB_PASSWORD=directus

# MySQL / MariaDB:
# DB_CLIENT=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=governance_portal
# DB_USER=directus
# DB_PASSWORD=directus

# ─── Authentication ─────────────────────────────────────────────────────
# Initial admin account created by `npx directus bootstrap`
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# ─── CORS ────────────────────────────────────────────────────────────────
# Allow the SvelteKit dev server
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# ─── File Storage ────────────────────────────────────────────────────────
STORAGE_LOCATIONS=local
STORAGE_LOCAL_DRIVER=local
STORAGE_LOCAL_ROOT=./uploads

# ─── WebSockets (Directus Realtime) ─────────────────────────────────────
WEBSOCKETS_ENABLED=true
