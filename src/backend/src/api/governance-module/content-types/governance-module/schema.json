{
  "kind": "collectionType",
  "collectionName": "governance_modules",
  "info": {
    "singularName": "governance-module",
    "pluralName": "governance-modules",
    "displayName": "Governance Module",
    "description": "Replaces the former IPlugin manifest. Each entry describes a governance module visible on the dashboard and in navigation."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "moduleId": {
      "type": "uid",
      "required": true
    },
    "displayName": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "description": {
      "type": "text"
    },
    "version": {
      "type": "string",
      "default": "1.0.0",
      "maxLength": 30
    },
    "icon": {
      "type": "string",
      "maxLength": 10,
      "default": "📋"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    }
  }
}
