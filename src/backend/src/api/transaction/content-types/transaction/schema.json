{
  "kind": "collectionType",
  "collectionName": "transactions",
  "info": {
    "singularName": "transaction",
    "pluralName": "transactions",
    "displayName": "Transaction",
    "description": "Finances module — income and expense records (replaces GovernancePortal.Plugins.Finances)."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "amount": {
      "type": "decimal",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["income", "expense", "transfer"],
      "default": "expense",
      "required": true
    },
    "description": {
      "type": "string",
      "maxLength": 300
    },
    "date": {
      "type": "date",
      "required": true
    },
    "reference": {
      "type": "string",
      "maxLength": 100
    }
  }
}
